# Copy to fastlane/.env and fill in values. Never commit the real .env file.

# Apple ID (required only for `bundle exec fastlane ios bootstrap_asc` — uses 2FA, not API key)
APPLE_ID=

# App Store Connect API key (Users and Access → Integrations → App Store Connect API)
ASC_KEY_ID=
ASC_ISSUER_ID=
# Path to AuthKey_XXXXXXXXXX.p8 (preferred) OR use ASC_KEY_CONTENT for CI
ASC_KEY_PATH=

# Numeric Apple ID of the app record in App Store Connect (after you create the app)
# Shown in the app URL: https://appstoreconnect.apple.com/apps/1234567890/...
ASC_APP_APPLE_ID=

# Optional overrides
# FASTLANE_TEAM_ID=YOUR_TEAM_ID
# FASTLANE_ITC_TEAM_ID=
